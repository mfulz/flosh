# Maintainer: Matthias Fulz <mfulz@olznet.de>

pkgname=flosh
pkgver=0.1.0
pkgrel=1
pkgdesc='Wayland-first capture, clipboard typing, and screenshot target workflow CLI'
arch=('any')
url='https://github.com/mfulz/flosh'
license=('MIT')
depends=(
  'python'
  'python-platformdirs'
  'python-tomlkit'
  'python-typer'
)
makedepends=(
  'python-build'
  'python-installer'
  'python-setuptools'
  'python-wheel'
)
optdepends=(
  'sway-contrib: grimshot screenshot backend'
  'grim: low-level Wayland screenshot tool used by grimshot'
  'slurp: Wayland area selection used by grimshot'
  'satty: default interactive screenshot editor'
  'swappy: legacy interactive screenshot editor'
  'wl-clipboard: Wayland clipboard integration'
  'xdotool: X11/XWayland typing backend, useful for Citrix/Wfica'
  'wtype: Wayland typing backend'
  'ydotool: evdev/uinput typing backend'
  'fzf: terminal target picker'
  'wofi: Wayland dmenu target picker'
  'rofi: dmenu target picker'
  'alacritty: default terminal for GUI-launched fzf'
  'libnotify: desktop notifications via notify-send'
  'tesseract: OCR support'
  'imagemagick: OCR preprocessing support'
)
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('060ff5e8ad97571c7b32a5040413c20f6eb20f25bcab20abc966a3a2ad70b945')

build() {
  cd "${pkgname}-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "${pkgname}-${pkgver}"
  python -m installer --destdir="${pkgdir}" dist/*.whl
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
