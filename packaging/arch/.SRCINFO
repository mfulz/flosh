	makedepends = python-setuptools
	makedepends = python-wheel
	depends = python
	depends = python-platformdirs
	depends = python-tomlkit
	depends = python-typer
	optdepends = sway-contrib: grimshot screenshot backend
	optdepends = grim: low-level Wayland screenshot tool used by grimshot
	optdepends = slurp: Wayland area selection used by grimshot
	optdepends = swappy: interactive screenshot editor
	optdepends = wl-clipboard: Wayland clipboard integration
	optdepends = xdotool: X11/XWayland typing backend, useful for Citrix/Wfica
	optdepends = wtype: Wayland typing backend
	optdepends = ydotool: evdev/uinput typing backend
	optdepends = fzf: terminal target picker
	optdepends = wofi: Wayland dmenu target picker
	optdepends = rofi: dmenu target picker
	optdepends = alacritty: default terminal for GUI-launched fzf
	optdepends = libnotify: desktop notifications via notify-send
	optdepends = tesseract: future OCR support
	optdepends = imagemagick: future OCR preprocessing support
